digraph agent_integration {
  graph [fontname="Helvetica,Arial,sans-serif" bgcolor="transparent" pad="0.6" ranksep="0.8" nodesep="0.8"]
  node  [fontname="Helvetica,Arial,sans-serif" shape=box style="filled,rounded" margin="0.25,0.12"]
  edge  [fontname="Helvetica,Arial,sans-serif" fontsize=9 fontcolor="#475569"]

  agent [label="AI Agent"
         shape=oval fillcolor="#F3E8FF" color="#7C3AED" fontcolor="#3B0764" width=2.0]

  skills [label="Skills\noperational playbooks\ninstalled to skills/"
          fillcolor="#FEF3C7" color="#D97706" fontcolor="#78350F"]

  mcp [label="MCP Tools\nbuild · lint · import\nop-run · op-status · op-signal"
       fillcolor="#EEF2FF" color="#4F46E5" fontcolor="#1E1B4B"]

  ops [label="Ops\n*.op.ts workflows\ndurable · observable · gate-able"
       fillcolor="#DBEAFE" color="#2563EB" fontcolor="#1E3A8A"]

  agent -> skills [label="reads — always-on guidance"    color="#D97706" fontcolor="#D97706"]
  agent -> mcp    [label="calls — programmatic actions"  color="#4F46E5" fontcolor="#4F46E5"]
  agent -> ops    [label="triggers via op-run\nmonitors via op-status" color="#2563EB" fontcolor="#2563EB"]

  skills -> mcp   [label="tells agent what to do\nMCP lets it do it"
                   style=dashed color="#94A3B8" fontcolor="#94A3B8"]
}
