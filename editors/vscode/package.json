{
  "name": "chant",
  "displayName": "Chant",
  "description": "Infrastructure-as-code toolkit — LSP integration for chant projects",
  "version": "0.0.5",
  "publisher": "intentius",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/INTENTIUS/chant",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:**/chant.config.ts",
    "workspaceContains:**/chant.config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Chant",
      "properties": {
        "chant.server.path": {
          "type": "string",
          "default": "chant",
          "description": "Path to the chant CLI binary"
        },
        "chant.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "serve",
            "lsp"
          ],
          "description": "Arguments passed to start the LSP server"
        },
        "chant.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Chant language server"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
