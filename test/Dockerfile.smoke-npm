# Persona: New User (npm and bun install paths)
# Questions answered:
#   - Can I install chant + a lexicon from npm packages?
#   - Can I `chant init --lexicon <X>` for every lexicon?
#   - Does the scaffolded project build and lint?
#   - Does a hand-crafted project build and lint?
#   - Do the real cross-lexicon examples build from packages?
# Flow: Stage 1 (bun) packs tarballs → Stage 2 (node) npm install + test → Stage 3 (bun) bun install + test

# ── Stage 1: builder ─────────────────────────────────────────────────────────
FROM oven/bun:latest AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y jq && rm -rf /var/lib/apt/lists/*

COPY . .

RUN bun install

# Fix workspace:* deps → real version, strip scripts so npm doesn't run them
RUN CORE_VERSION=$(jq -r '.version' packages/core/package.json) && \
    echo "Core version: $CORE_VERSION" && \
    # Core: just strip scripts
    cd /app/packages/core && \
    jq 'del(.scripts)' package.json > tmp.json && mv tmp.json package.json && \
    # Each lexicon: replace workspace:* with version, strip scripts
    for lex in aws azure gcp gitlab k8s flyway docker; do \
      cd /app/lexicons/$lex && \
      jq --arg v "$CORE_VERSION" \
        '(.dependencies // {}) |= with_entries(if .value == "workspace:*" then .value = $v else . end) | del(.scripts)' \
        package.json > tmp.json && mv tmp.json package.json; \
    done

# Pack tarballs:
# - Core: bun pm pack works (src/ and bin/ are not gitignored)
# - Lexicons: tar — bun pm pack with del(.scripts) excludes gitignored dist/.
#   smoke.sh ran prepack locally; COPY . . already brought dist/ into this stage.
RUN mkdir -p /tarballs && \
    cd /app/packages/core && rm -f *.tgz && bun pm pack && mv *.tgz /tarballs/core.tgz && \
    for lex in aws azure gcp gitlab k8s flyway docker; do \
      tar czf /tarballs/lexicon-${lex}.tgz \
        -C /app/lexicons/$lex \
        --transform='s|^\./|package/|' \
        ./package.json ./src ./dist || exit 1; \
    done

# ── Stage 2: test (node only, no bun) ────────────────────────────────────────
FROM node:22-slim AS test-node

RUN apt-get update && apt-get install -y jq && rm -rf /var/lib/apt/lists/*

# Install tsx globally — this is the fallback runtime the bin/chant wrapper uses
RUN npm install -g tsx

# Copy tarballs from builder
COPY --from=builder /tarballs /tarballs

# Copy example source directories for validation
COPY --from=builder /app/examples /examples

# Copy and run the test script — RUN so build fails if tests fail
COPY test/npm-smoke.sh /npm-smoke.sh
RUN chmod +x /npm-smoke.sh
RUN RUNTIME=npm /npm-smoke.sh

# Leave a marker so stage 3 can force this stage to run
RUN echo "node-tests-passed" > /test-node-ok

# ── Stage 3: test (bun user installing from npm) ─────────────────────────────
# Use node base (provides npm) + install bun on top. bun's own image lacks npm,
# and bun add from tarballs doesn't deduplicate transitive deps properly.
FROM node:22-slim AS test-bun

RUN apt-get update && apt-get install -y jq curl unzip && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:$PATH"

# Copy tarballs from builder
COPY --from=builder /tarballs /tarballs

# Copy example source directories for validation
COPY --from=builder /app/examples /examples

# Force stage 2 to run by depending on its output
COPY --from=test-node /test-node-ok /test-node-ok

COPY test/npm-smoke.sh /npm-smoke.sh
RUN chmod +x /npm-smoke.sh
RUN RUNTIME=bun /npm-smoke.sh
