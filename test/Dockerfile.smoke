# Workspace smoke test — validates chant CLI in a Node.js workspace
#
# Persona: Developer / Contributor (Node.js workspace)
# Questions answered:
#   - Does fresh checkout + npm install work?
#   - Does every CLI command work for every lexicon? (build, lint, list, doctor, init)
#   - Do MCP and LSP servers start?
#   - Do output formats work? (json, yaml, sarif)
#   - Does `chant init lexicon` scaffold correctly?
#   - Do multi-stack builds work?
#   - Do all root examples build?
# Flow: COPY workspace → npm install → validate dist/ → RUN integration.sh
FROM node:22-slim

WORKDIR /app

# Install system deps
RUN apt-get update && apt-get install -y jq curl && rm -rf /var/lib/apt/lists/*

# Install tsx globally — used by bin/chant
RUN npm install -g tsx

# Copy workspace
COPY . .

# Install dependencies
RUN npm install

# Validate that dist/ artifacts exist — codegen runs on the host before docker build.
# Run: just prepack  (or npm run --prefix lexicons/<lex> prepack) before building this Dockerfile.
RUN for lex in aws azure gcp gitlab k8s flyway docker; do \
      if [ ! -f "lexicons/$lex/dist/manifest.json" ]; then \
        echo "ERROR: lexicons/$lex/dist/ not found. Run codegen first: npm run --prefix lexicons/$lex prepack" >&2; \
        exit 1; \
      fi; \
    done

# Run integration tests during build — build fails if tests fail
COPY test/integration.sh /app/test/integration.sh
RUN chmod +x /app/test/integration.sh && CHANT_RUNTIME=npx /app/test/integration.sh

# Put chant on the PATH
ENV PATH="/app/lexicons/gitlab/node_modules/.bin:/app/lexicons/aws/node_modules/.bin:${PATH}"

CMD ["bash"]
