{
  "name": "@intentius/chant-lexicon-azure",
  "version": "0.0.15",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "src/",
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./manifest": "./dist/manifest.json",
    "./meta": "./dist/meta.json",
    "./types": "./dist/types/index.d.ts"
  },
  "scripts": {
    "generate": "bun run src/codegen/generate-cli.ts",
    "bundle": "bun run src/package-cli.ts",
    "validate": "bun run src/validate-cli.ts",
    "docs": "bun src/codegen/docs-cli.ts",
    "prepack": "bun run bundle && bun run validate"
  },
  "dependencies": {
    "@intentius/chant": "workspace:*",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
