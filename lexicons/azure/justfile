# Default recipe - list all available commands
default:
    @just --list

# Generate types and metadata from ARM schemas
generate:
    npx tsx src/codegen/generate-cli.ts

# Validate generated artifacts
validate:
    npx tsx src/validate-cli.ts

# Generate docs site, install deps, and start dev server
docs:
    DOCS_BASE_PATH=/ npx tsx src/codegen/docs-cli.ts
    npm install --prefix docs
    npm run --prefix docs dev --port 4322

# Build docs site for production
docs-build:
    DOCS_BASE_PATH=/ npx tsx src/codegen/docs-cli.ts
    npm install --prefix docs
    npm run --prefix docs build

# Fetch Azure Quickstart Templates for roundtrip testing
fetch-quickstarts:
    npx tsx scripts/fetch-quickstart-templates.ts

# Package the lexicon (generate + validate)
package: generate validate
