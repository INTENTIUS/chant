{
  "name": "vnet-vms-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun test",
    "build": "chant build src --lexicon azure -o template.json",
    "dev": "chant build src --lexicon azure --watch",
    "lint": "chant lint src",
    "deploy": "az deployment group create --resource-group \"$RESOURCE_GROUP\" --template-file template.json",
    "teardown": "az group delete --name \"$RESOURCE_GROUP\" --yes"
  },
  "dependencies": {
    "@intentius/chant-lexicon-azure": "workspace:*",
    "@intentius/chant": "workspace:*"
  },
  "devDependencies": {
    "typescript": "*"
  }
}
