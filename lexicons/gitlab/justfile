# Default recipe - list all available commands
default:
    @just --list

# Generate types and metadata from GitLab CI schema
generate:
    npx tsx src/codegen/generate-cli.ts

# Generate docs site, install deps, and start dev server
docs:
    npx tsx src/codegen/docs-cli.ts
    npm install --prefix docs
    npm run --prefix docs dev

# Build docs site for production
docs-build:
    npx tsx src/codegen/docs-cli.ts
    npm install --prefix docs
    npm run --prefix docs build

# Run all tests
test:
    npx vitest run

# Import real-world GitLab CI samples and run roundtrip tests
import-samples *ARGS:
    bash scripts/import-gitlab-samples.sh {{ARGS}}

# Run full roundtrip (parse → generate → import → serialize back)
full-roundtrip *ARGS:
    bash scripts/full-roundtrip.sh {{ARGS}}

# Package the lexicon (generate)
package: generate
