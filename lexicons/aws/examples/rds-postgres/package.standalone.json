{
  "name": "rds-postgres-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun test",
    "build": "chant build src --lexicon aws",
    "lint": "chant lint src",
    "dev": "chant build src --lexicon aws --watch",
    "setup": "bash setup.sh",
    "deploy": "bash setup.sh && chant build src --lexicon aws --output stack.json && aws cloudformation deploy --template-file stack.json --stack-name rds-postgres-example --no-fail-on-empty-changeset",
    "teardown": "aws cloudformation delete-stack --stack-name rds-postgres-example"
  },
  "dependencies": {
    "@intentius/chant": "^0.0.14",
    "@intentius/chant-lexicon-aws": "^0.0.14"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
