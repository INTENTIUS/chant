{
  "name": "lambda-s3-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "chant build src --lexicon aws -o template.json",
    "lint": "chant lint src",
    "dev": "chant build src --lexicon aws --watch -o template.json",
    "test": "bun test",
    "deploy": "aws cloudformation deploy --template-file template.json --stack-name lambda-s3 --capabilities CAPABILITY_NAMED_IAM",
    "teardown": "aws cloudformation delete-stack --stack-name lambda-s3"
  },
  "dependencies": {
    "@intentius/chant-lexicon-aws": "*",
    "@intentius/chant": "*"
  },
  "devDependencies": {
    "typescript": "*"
  }
}
