{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Outputs": {
    "ServiceArn": {
      "Value": {
        "Fn::GetAtt": [
          "solrService",
          "ServiceArn"
        ]
      }
    },
    "ServiceName": {
      "Value": {
        "Fn::GetAtt": [
          "solrService",
          "Name"
        ]
      }
    }
  },
  "Parameters": {
    "accessPointId": {
      "Description": "EFS Access Point ID",
      "Type": "String"
    },
    "albDnsName": {
      "Description": "ALB DNS Name",
      "Type": "String"
    },
    "albSgId": {
      "Description": "ALB Security Group ID",
      "Type": "String"
    },
    "appName": {
      "Default": "solr",
      "Description": "App name",
      "Type": "String"
    },
    "clusterArn": {
      "Description": "ECS Cluster ARN",
      "Type": "String"
    },
    "efsId": {
      "Description": "EFS File System ID",
      "Type": "String"
    },
    "executionRoleArn": {
      "Description": "Execution Role ARN",
      "Type": "String"
    },
    "listenerArn": {
      "Description": "ALB Listener ARN",
      "Type": "String"
    },
    "privateSubnet1": {
      "Description": "Private Subnet 1",
      "Type": "String"
    },
    "privateSubnet2": {
      "Description": "Private Subnet 2",
      "Type": "String"
    },
    "solrCollection": {
      "Default": "lucene",
      "Description": "Solr collection name",
      "Type": "String"
    },
    "solrImage": {
      "Default": "solr:9",
      "Description": "Solr Docker image",
      "Type": "String"
    },
    "vpcId": {
      "Description": "VPC ID",
      "Type": "String"
    }
  },
  "Resources": {
    "solrLogGroup": {
      "Properties": {
        "RetentionInDays": 30
      },
      "Type": "AWS::Logs::LogGroup"
    },
    "solrRule": {
      "Properties": {
        "Actions": [
          {
            "TargetGroupArn": {
              "Fn::GetAtt": [
                "solrTargetGroup",
                "TargetGroupArn"
              ]
            },
            "Type": "forward"
          }
        ],
        "Conditions": [
          {
            "Field": "path-pattern",
            "PathPatternConfig": {
              "Values": [
                "/solr",
                "/solr/*"
              ]
            }
          }
        ],
        "ListenerArn": {
          "Ref": "listenerArn"
        },
        "Priority": 100
      },
      "Type": "AWS::ElasticLoadBalancingV2::ListenerRule"
    },
    "solrScalableTarget": {
      "Properties": {
        "MaxCapacity": 6,
        "MinCapacity": 1,
        "ResourceId": {
          "Fn::Join": [
            "/",
            [
              "service",
              {
                "Fn::Select": [
                  "1",
                  {
                    "Fn::Split": [
                      "/",
                      {
                        "Ref": "clusterArn"
                      }
                    ]
                  }
                ]
              },
              {
                "Fn::GetAtt": [
                  "solrService",
                  "Name"
                ]
              }
            ]
          ]
        },
        "ScalableDimension": "ecs:service:DesiredCount",
        "ServiceNamespace": "ecs"
      },
      "Type": "AWS::ApplicationAutoScaling::ScalableTarget"
    },
    "solrScalingPolicy": {
      "Properties": {
        "PolicyName": {
          "Fn::Sub": "${AWS::StackName}-cpu"
        },
        "PolicyType": "TargetTrackingScaling",
        "ResourceId": {
          "Fn::Join": [
            "/",
            [
              "service",
              {
                "Fn::Select": [
                  "1",
                  {
                    "Fn::Split": [
                      "/",
                      {
                        "Ref": "clusterArn"
                      }
                    ]
                  }
                ]
              },
              {
                "Fn::GetAtt": [
                  "solrService",
                  "Name"
                ]
              }
            ]
          ]
        },
        "ScalableDimension": "ecs:service:DesiredCount",
        "ServiceNamespace": "ecs",
        "TargetTrackingScalingPolicyConfiguration": {
          "PredefinedMetricSpecification": {
            "PredefinedMetricType": "ECSServiceAverageCPUUtilization"
          },
          "TargetValue": 60
        }
      },
      "Type": "AWS::ApplicationAutoScaling::ScalingPolicy"
    },
    "solrService": {
      "DependsOn": "solrRule",
      "Properties": {
        "Cluster": {
          "Ref": "clusterArn"
        },
        "DesiredCount": 1,
        "HealthCheckGracePeriodSeconds": 60,
        "LaunchType": "FARGATE",
        "LoadBalancers": [
          {
            "ContainerName": "app",
            "ContainerPort": 8983,
            "TargetGroupArn": {
              "Fn::GetAtt": [
                "solrTargetGroup",
                "TargetGroupArn"
              ]
            }
          }
        ],
        "NetworkConfiguration": {
          "AwsvpcConfiguration": {
            "AssignPublicIp": "DISABLED",
            "SecurityGroups": [
              {
                "Fn::GetAtt": [
                  "solrTaskSg",
                  "GroupId"
                ]
              }
            ],
            "Subnets": [
              {
                "Ref": "privateSubnet1"
              },
              {
                "Ref": "privateSubnet2"
              }
            ]
          }
        },
        "TaskDefinition": {
          "Fn::GetAtt": [
            "solrTaskDef",
            "TaskDefinitionArn"
          ]
        }
      },
      "Type": "AWS::ECS::Service"
    },
    "solrTargetGroup": {
      "Properties": {
        "HealthCheckPath": "/solr/",
        "Port": 8983,
        "Protocol": "HTTP",
        "TargetType": "ip",
        "VpcId": {
          "Ref": "vpcId"
        }
      },
      "Type": "AWS::ElasticLoadBalancingV2::TargetGroup"
    },
    "solrTaskDef": {
      "Properties": {
        "ContainerDefinitions": [
          {
            "Command": [
              "solr-precreate",
              {
                "Ref": "solrCollection"
              }
            ],
            "Environment": [
              {
                "Name": "SOLR_HEAP",
                "Value": "1g"
              }
            ],
            "Essential": true,
            "Image": {
              "Ref": "solrImage"
            },
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Ref": "solrLogGroup"
                },
                "awslogs-region": {
                  "Fn::Sub": "${AWS::Region}"
                },
                "awslogs-stream-prefix": "ecs"
              }
            },
            "MountPoints": [
              {
                "ContainerPath": "/var/solr",
                "SourceVolume": "efs-0"
              }
            ],
            "Name": "app",
            "PortMappings": [
              {
                "ContainerPort": 8983,
                "Protocol": "tcp"
              }
            ]
          }
        ],
        "Cpu": "1024",
        "ExecutionRoleArn": {
          "Ref": "executionRoleArn"
        },
        "Memory": "2048",
        "NetworkMode": "awsvpc",
        "RequiresCompatibilities": [
          "FARGATE"
        ],
        "TaskRoleArn": {
          "Fn::GetAtt": [
            "solrTaskRole",
            "Arn"
          ]
        },
        "Volumes": [
          {
            "EFSVolumeConfiguration": {
              "AuthorizationConfig": {
                "AccessPointId": {
                  "Ref": "accessPointId"
                }
              },
              "FileSystemId": {
                "Ref": "efsId"
              },
              "TransitEncryption": "ENABLED"
            },
            "Name": "efs-0"
          }
        ]
      },
      "Type": "AWS::ECS::TaskDefinition"
    },
    "solrTaskRole": {
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              }
            }
          ],
          "Version": "2012-10-17"
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonElasticFileSystemClientReadWriteAccess"
        ]
      },
      "Type": "AWS::IAM::Role"
    },
    "solrTaskSg": {
      "Properties": {
        "GroupDescription": "Fargate task security group",
        "SecurityGroupIngress": [
          {
            "FromPort": 8983,
            "IpProtocol": "tcp",
            "SourceSecurityGroupId": {
              "Ref": "albSgId"
            },
            "ToPort": 8983
          }
        ],
        "VpcId": {
          "Ref": "vpcId"
        }
      },
      "Type": "AWS::EC2::SecurityGroup"
    }
  }
}