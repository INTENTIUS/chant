{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Outputs": {
    "BucketArns": {
      "Value": {
        "Fn::GetAtt": [
          "documentsBucket",
          "Arn"
        ]
      }
    },
    "TableArns": {
      "Value": {
        "Fn::GetAtt": [
          "productsTable",
          "Arn"
        ]
      }
    }
  },
  "Parameters": {
    "appName": {
      "Default": "solr",
      "Description": "App name",
      "Type": "String"
    },
    "documentsBucketName": {
      "Default": "",
      "Description": "documents S3 bucket name (leave blank to create)",
      "Type": "String"
    },
    "productsStreamArn": {
      "Default": "",
      "Description": "products DynamoDB stream ARN",
      "Type": "String"
    },
    "productsTableArn": {
      "Default": "",
      "Description": "products DynamoDB table ARN (leave blank to create)",
      "Type": "String"
    },
    "solrCollection": {
      "Default": "lucene",
      "Description": "Solr collection name",
      "Type": "String"
    },
    "solrUrl": {
      "Description": "Solr base URL (e.g. http://alb-dns/solr)",
      "Type": "String"
    }
  },
  "Resources": {
    "documentsBucket": {
      "DependsOn": "documentsRelayPermission",
      "Properties": {
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "BucketName": {
          "Fn::Sub": "${AWS::StackName}-${appName}-documents"
        },
        "NotificationConfiguration": {
          "LambdaConfigurations": [
            {
              "Event": "s3:ObjectCreated:*",
              "Filter": {
                "S3Key": {
                  "Rules": [
                    {
                      "Name": "prefix",
                      "Value": "data/"
                    }
                  ]
                }
              },
              "Function": {
                "Fn::GetAtt": [
                  "documentsRelayFn",
                  "Arn"
                ]
              }
            }
          ]
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        }
      },
      "Type": "AWS::S3::Bucket"
    },
    "documentsRelayFn": {
      "Properties": {
        "Code": {
          "ZipFile": "import json, urllib.request, os, boto3\ndef handler(event, context):\n    s3 = boto3.client('s3')\n    for r in event['Records']:\n        bucket = r['s3']['bucket']['name']\n        key = r['s3']['object']['key']\n        obj = s3.get_object(Bucket=bucket, Key=key)\n        content = obj['Body'].read().decode('utf-8')\n        doc = {'id': key, 'content': content}\n        req = urllib.request.Request(\n            f\"{os.environ['SOLR_URL']}/{os.environ['COLLECTION']}/update/json/docs?commit=true\",\n            data=json.dumps([doc]).encode(),\n            headers={'Content-Type': 'application/json'}, method='POST')\n        urllib.request.urlopen(req)\n"
        },
        "Environment": {
          "Variables": {
            "BUCKET_NAME": {
              "Fn::Sub": "${AWS::StackName}-${appName}-documents"
            },
            "COLLECTION": {
              "Ref": "solrCollection"
            },
            "SOLR_URL": {
              "Ref": "solrUrl"
            }
          }
        },
        "FunctionName": {
          "Fn::Sub": "${AWS::StackName}-${appName}-documents-relay"
        },
        "Handler": "index.handler",
        "Role": {
          "Fn::GetAtt": [
            "documentsRelayRole",
            "Arn"
          ]
        },
        "Runtime": "python3.12",
        "Timeout": 30
      },
      "Type": "AWS::Lambda::Function"
    },
    "documentsRelayLogGroup": {
      "Properties": {
        "LogGroupName": {
          "Fn::Sub": "/aws/lambda/${AWS::StackName}-${appName}-documents-relay"
        },
        "RetentionInDays": 30
      },
      "Type": "AWS::Logs::LogGroup"
    },
    "documentsRelayPermission": {
      "Properties": {
        "Action": "lambda:InvokeFunction",
        "FunctionName": {
          "Fn::GetAtt": [
            "documentsRelayFn",
            "Arn"
          ]
        },
        "Principal": "s3.amazonaws.com",
        "SourceArn": {
          "Fn::Join": [
            "",
            [
              "arn:aws:s3:::",
              {
                "Fn::Sub": "${AWS::StackName}-${appName}-documents"
              }
            ]
          ]
        }
      },
      "Type": "AWS::Lambda::Permission"
    },
    "documentsRelayRole": {
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              }
            }
          ],
          "Version": "2012-10-17"
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ],
        "Policies": [
          {
            "PolicyDocument": {
              "Statement": [
                {
                  "Action": [
                    "s3:GetObject",
                    "s3:GetObjectVersion",
                    "s3:GetBucketLocation",
                    "s3:ListBucket",
                    "s3:ListBucketVersions"
                  ],
                  "Effect": "Allow",
                  "Resource": [
                    {
                      "Fn::Join": [
                        "",
                        [
                          "arn:aws:s3:::",
                          {
                            "Fn::Sub": "${AWS::StackName}-${appName}-documents"
                          }
                        ]
                      ]
                    },
                    {
                      "Fn::Join": [
                        "",
                        [
                          "arn:aws:s3:::",
                          {
                            "Fn::Sub": "${AWS::StackName}-${appName}-documents"
                          },
                          "/*"
                        ]
                      ]
                    }
                  ]
                }
              ],
              "Version": "2012-10-17"
            },
            "PolicyName": "S3ReadOnly"
          }
        ]
      },
      "Type": "AWS::IAM::Role"
    },
    "productsEsm": {
      "Properties": {
        "BisectBatchOnFunctionError": true,
        "EventSourceArn": {
          "Fn::GetAtt": [
            "productsTable",
            "StreamArn"
          ]
        },
        "FunctionName": {
          "Fn::GetAtt": [
            "productsRelayFn",
            "Arn"
          ]
        },
        "StartingPosition": "TRIM_HORIZON"
      },
      "Type": "AWS::Lambda::EventSourceMapping"
    },
    "productsRelayFn": {
      "Properties": {
        "Code": {
          "ZipFile": "import json, urllib.request, os\ndef handler(event, context):\n    docs = []\n    for r in event['Records']:\n        if r['eventName'] in ('INSERT', 'MODIFY'):\n            img = r['dynamodb']['NewImage']\n            docs.append({f: list(v.values())[0] for f, v in img.items()})\n        elif r['eventName'] == 'REMOVE':\n            pk = list(r['dynamodb']['Keys']['id'].values())[0]\n            req = urllib.request.Request(\n                f\"{os.environ['SOLR_URL']}/{os.environ['COLLECTION']}/update?commit=true\",\n                data=json.dumps({'delete': {'id': pk}}).encode(),\n                headers={'Content-Type': 'application/json'}, method='POST')\n            urllib.request.urlopen(req)\n            continue\n    if docs:\n        req = urllib.request.Request(\n            f\"{os.environ['SOLR_URL']}/{os.environ['COLLECTION']}/update/json/docs?commit=true\",\n            data=json.dumps(docs).encode(),\n            headers={'Content-Type': 'application/json'}, method='POST')\n        urllib.request.urlopen(req)\n"
        },
        "Environment": {
          "Variables": {
            "COLLECTION": {
              "Ref": "solrCollection"
            },
            "SOLR_URL": {
              "Ref": "solrUrl"
            },
            "TABLE_NAME": {
              "Ref": "productsTable"
            }
          }
        },
        "FunctionName": {
          "Fn::Sub": "${AWS::StackName}-${appName}-products-relay"
        },
        "Handler": "index.handler",
        "Role": {
          "Fn::GetAtt": [
            "productsRelayRole",
            "Arn"
          ]
        },
        "Runtime": "python3.12",
        "Timeout": 30
      },
      "Type": "AWS::Lambda::Function"
    },
    "productsRelayLogGroup": {
      "Properties": {
        "LogGroupName": {
          "Fn::Sub": "/aws/lambda/${AWS::StackName}-${appName}-products-relay"
        },
        "RetentionInDays": 30
      },
      "Type": "AWS::Logs::LogGroup"
    },
    "productsRelayRole": {
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              }
            }
          ],
          "Version": "2012-10-17"
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ],
        "Policies": [
          {
            "PolicyDocument": {
              "Statement": [
                {
                  "Action": [
                    "dynamodb:GetRecords",
                    "dynamodb:GetShardIterator",
                    "dynamodb:DescribeStream",
                    "dynamodb:ListStreams"
                  ],
                  "Effect": "Allow",
                  "Resource": {
                    "Fn::GetAtt": [
                      "productsTable",
                      "StreamArn"
                    ]
                  }
                }
              ],
              "Version": "2012-10-17"
            },
            "PolicyName": "DynamoDBStreamRead"
          }
        ]
      },
      "Type": "AWS::IAM::Role"
    },
    "productsTable": {
      "Properties": {
        "AttributeDefinitions": [
          {
            "AttributeName": "id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "KeySchema": [
          {
            "AttributeName": "id",
            "KeyType": "HASH"
          }
        ],
        "StreamSpecification": {
          "StreamViewType": "NEW_AND_OLD_IMAGES"
        },
        "TableName": {
          "Fn::Sub": "${AWS::StackName}-${appName}-products"
        }
      },
      "Type": "AWS::DynamoDB::Table"
    }
  }
}