default:
    @just --list

generate:
    npx tsx src/codegen/generate-cli.ts

validate:
    npx tsx src/validate-cli.ts

docs:
    npx tsx src/codegen/docs-cli.ts
    npm install --prefix docs
    npm run --prefix docs dev

docs-build:
    npx tsx src/codegen/docs-cli.ts
    npm install --prefix docs
    npm run --prefix docs build

package: generate validate
