digraph slurm_output_routing {
  rankdir=LR
  graph [fontname="Helvetica,Arial,sans-serif" bgcolor="transparent" pad="0.5" ranksep="1.0" nodesep="0.5"]
  node  [fontname="Helvetica,Arial,sans-serif" shape=box style="filled,rounded" margin="0.22,0.12"]
  edge  [fontname="Helvetica,Arial,sans-serif" fontsize=9 fontcolor="#475569" color="#6366F1"]

  subgraph cluster_src {
    label="chant resources" style=filled fillcolor="#EEF2FF" color="#4F46E5" penwidth=2
    fontname="Helvetica,Arial,sans-serif"

    cluster  [label="SlurmCluster\ncontrolMachine · clusterName\nschedulerType · authType"
              fillcolor="#E0E7FF" color="#4F46E5" fontcolor="#1E1B4B"]
    node_res [label="SlurmNode\nhostname · cpus · mem\ngres (GPU) · state"
              fillcolor="#E0E7FF" color="#4F46E5" fontcolor="#1E1B4B"]
    part     [label="SlurmPartition\nnodes · maxTime\ndefault · state"
              fillcolor="#E0E7FF" color="#4F46E5" fontcolor="#1E1B4B"]
    job      [label="SlurmJob\nscript · ntasks\ngpus · partition"
              fillcolor="#E0E7FF" color="#4F46E5" fontcolor="#1E1B4B"]
  }

  subgraph cluster_out {
    label="dist/ (output files)" style=filled fillcolor="#F0FDF4" color="#16A34A" penwidth=2
    fontname="Helvetica,Arial,sans-serif"

    sconf  [label="slurm.conf\nglobal config\n+ node definitions"
            fillcolor="#DCFCE7" color="#15803D" fontcolor="#14532D"]
    gconf  [label="gres.conf\nGPU resource\ndefinitions"
            fillcolor="#DCFCE7" color="#15803D" fontcolor="#14532D"]
    pconf  [label="partitions.conf\npartition\ndefinitions"
            fillcolor="#DCFCE7" color="#15803D" fontcolor="#14532D"]
    script [label="job-<name>.sh\nbatch job script\n(sbatch-ready)"
            fillcolor="#DCFCE7" color="#15803D" fontcolor="#14532D"]
  }

  cluster  -> sconf  [label="chant build"]
  node_res -> sconf  [label="NodeName= lines"]
  node_res -> gconf  [label="if gres defined"]
  part     -> pconf  [label="chant build"]
  job      -> script [label="chant build"]
}
