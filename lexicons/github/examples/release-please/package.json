{
  "name": "github-release-please-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "chant build src --lexicon github -o .github/workflows/release-please.yml",
    "lint": "chant lint src",
    "dev": "chant build src --lexicon github --watch -o .github/workflows/release-please.yml"
  },
  "dependencies": {
    "@intentius/chant-lexicon-github": "workspace:*",
    "@intentius/chant": "workspace:*"
  },
  "devDependencies": {
    "typescript": "*"
  }
}
