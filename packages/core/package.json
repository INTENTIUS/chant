{
  "name": "@intentius/chant",
  "version": "0.7.0",
  "description": "Declarative infrastructure-as-code toolkit — TypeScript on Node.js",
  "license": "Apache-2.0",
  "homepage": "https://intentius.io/chant",
  "repository": {
    "type": "git",
    "url": "https://github.com/INTENTIUS/chant.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/INTENTIUS/chant/issues"
  },
  "keywords": [
    "infrastructure-as-code",
    "iac",
    "typescript",
    "declarative",
    "cloudformation",
    "aws",
    "devops"
  ],
  "type": "module",
  "files": [
    "src/",
    "dist/",
    "bin/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "chant": "./bin/chant"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "development": "./src/cli/index.ts",
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    },
    "./cli/*": {
      "development": "./src/cli/*.ts",
      "types": "./dist/cli/*.d.ts",
      "default": "./dist/cli/*.js"
    },
    "./op": {
      "development": "./src/op/index.ts",
      "types": "./dist/op/index.d.ts",
      "default": "./dist/op/index.js"
    },
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node ../../scripts/copy-dist-assets.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "picomatch": "^4.0.3",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "zod": "^4.3.6"
  }
}
