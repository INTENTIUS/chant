# === Domain ===
CRDB_DOMAIN=crdb.example.com              # REQUIRED — base domain for UI ingress (subdomains: eks.*, aks.*, gke.*)

# === AWS (EKS) ===
# AWS_REGION=us-east-1                    # optional, default: us-east-1
# EKS_CLUSTER_NAME=eks-cockroachdb        # optional, default: eks-cockroachdb
ALB_CERT_ARN=                              # REQUIRED — ACM certificate ARN for ALB TLS
EXTERNAL_DNS_ROLE_ARN=                     # REQUIRED — IAM role ARN for ExternalDNS

# === Azure (AKS) ===
# AKS_CLUSTER_NAME=aks-cockroachdb        # optional, default: aks-cockroachdb
# AZURE_RESOURCE_GROUP=cockroachdb-rg     # optional, default: cockroachdb-rg
AZURE_SUBSCRIPTION_ID=                     # REQUIRED
AZURE_TENANT_ID=                           # REQUIRED
EXTERNAL_DNS_CLIENT_ID=                    # REQUIRED — managed identity client ID

# === GCP (GKE) ===
# GKE_CLUSTER_NAME=gke-cockroachdb        # optional, default: gke-cockroachdb
GCP_PROJECT_ID=                            # REQUIRED
EXTERNAL_DNS_GSA_EMAIL=                    # REQUIRED — service account email

# === Shared ===
VPN_SHARED_SECRET=                         # REQUIRED — IPsec pre-shared key (DO NOT use "changeme")

# === Post-deploy (populated by scripts/load-outputs.sh — do not set manually) ===
# AWS_VPN_PUBLIC_IP=                       # extracted from CloudFormation outputs
# AZURE_VPN_PUBLIC_IP=                     # extracted from ARM deployment outputs
# GCP_VPN_PUBLIC_IP=                       # extracted from GCP deployment outputs
