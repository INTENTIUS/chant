# === GCP ===
GCP_PROJECT_ID=                            # REQUIRED — GCP project ID
GCP_PROJECT_NUMBER=                        # REQUIRED — GCP project number (gcloud projects describe $GCP_PROJECT_ID --format='value(projectNumber)')
CRDB_DOMAIN=crdb.example.com              # REQUIRED — base domain for UI ingress (subdomains: east.*, central.*, west.*)

# === Temporal Cloud ===
TEMPORAL_ADDRESS=                          # REQUIRED — e.g. myns.a2dd6.tmprl.cloud:7233  (Settings → Namespaces)
TEMPORAL_NAMESPACE=                        # REQUIRED — e.g. myns.a2dd6
TEMPORAL_API_KEY=                          # REQUIRED — Temporal Cloud API key (Settings → API Keys)
