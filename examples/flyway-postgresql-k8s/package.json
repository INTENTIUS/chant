{
  "name": "flyway-postgresql-k8s-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "cluster-create": "k3d cluster create flyway-pg -p '30432:30432@server:0' --wait",
    "cluster-delete": "k3d cluster delete flyway-pg",
    "build": "chant build src --lexicon k8s -o k8s.yaml && chant build src --lexicon flyway -o flyway.toml",
    "lint": "chant lint src",
    "apply": "kubectl apply -f k8s.yaml",
    "wait": "kubectl -n flyway-pg rollout status statefulset/postgres --timeout=120s",
    "migrate": "flyway migrate -environment=local",
    "info": "flyway info -environment=local",
    "run": "bun run cluster-create && bun run build && bun run apply && bun run wait && bun run migrate",
    "teardown": "k3d cluster delete flyway-pg"
  },
  "dependencies": {
    "@intentius/chant": "workspace:*",
    "@intentius/chant-lexicon-k8s": "workspace:*",
    "@intentius/chant-lexicon-flyway": "workspace:*"
  }
}
