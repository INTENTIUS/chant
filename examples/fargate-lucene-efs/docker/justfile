COMPOSE    := "docker compose -f dist/docker-compose.yml --project-name lucene-solr"
SOLR       := "http://localhost:8983/solr"
COLLECTION := "lucene"
DYNAMO     := "aws dynamodb --endpoint-url http://localhost:8000 --region us-east-1 --no-cli-pager"
MC         := "docker run --rm --network lucene-solr_solrNet -e MC_HOST_local=http://minioadmin:minioadmin@minio:9000 minio/mc:latest"

# E2E test: launch stack, exercise both relays, destroy
test:
    bun test e2e.test.ts

# Volume test: assumes `just up` is already running
volume:
    bun test volume.test.ts

# Build compose file from chant sources
build:
    npm run build

# Start all services (builds compose file first)
up: build
    {{COMPOSE}} up --build -d

# Stop services (preserves volumes)
down:
    {{COMPOSE}} down

# Stop services and delete volumes
clean:
    {{COMPOSE}} down -v

# Follow logs (optionally filter by service name)
logs *svc:
    {{COMPOSE}} logs -f {{svc}}

# Show service health/status
ps:
    {{COMPOSE}} ps

# One-time setup: create MinIO bucket
# (Solr core "lucene" is created automatically via solr-precreate at startup)
setup:
    {{MC}} mb --ignore-existing local/documents

# Open Solr admin UI in browser
solr-ui:
    open {{SOLR}}/#/{{COLLECTION}}/query

# Search Solr (default: all docs)
search q="*:*":
    curl -s "{{SOLR}}/{{COLLECTION}}/select?q={{q}}&wt=json" | jq '.response | {numFound, docs}'

# Create DynamoDB products table with streams enabled
create-table:
    {{DYNAMO}} create-table \
      --table-name products \
      --attribute-definitions AttributeName=id,AttributeType=S \
      --key-schema AttributeName=id,KeyType=HASH \
      --billing-mode PAY_PER_REQUEST \
      --stream-specification StreamEnabled=true,StreamViewType=NEW_AND_OLD_IMAGES

# Insert a product (example: just put-item '{"id":{"S":"1"},"title":{"S":"Widget"}}')
put-item item='{"id": {"S": "1"}, "title": {"S": "Widget"}}':
    {{DYNAMO}} put-item --table-name products --item '{{item}}'

# Delete a product by id
delete-item id="1":
    {{DYNAMO}} delete-item --table-name products --key '{"id": {"S": "{{id}}"}}'

# Upload a document to MinIO (triggers minio-relay → Solr)
upload-doc file="README.md":
    AWS_ACCESS_KEY_ID=minioadmin AWS_SECRET_ACCESS_KEY=minioadmin \
      aws s3 cp {{file}} s3://documents/data/$(basename {{file}}) \
      --endpoint-url http://localhost:9000 \
      --region us-east-1

# End-to-end smoke: create table → insert product → wait → verify in Solr
verify: create-table
    just put-item '{"id": {"S": "smoke"}, "title": {"S": "Smoke Test"}}'
    sleep 3
    just search "id:smoke"
