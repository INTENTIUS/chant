chant := "bun run ../../packages/core/src/cli/main.ts"

# Build K8s manifests
build:
    {{chant}} build src --lexicon k8s -o k8s.yaml

# Lint all source files
lint:
    {{chant}} lint src

# Apply K8s manifests
apply:
    kubectl apply -f k8s.yaml

# Wait for worker rollout
wait:
    kubectl -n batch-workers rollout status deployment/queue-worker --timeout=120s

# Check deployment status
status:
    kubectl get pods -n batch-workers
    kubectl get cronjobs -n batch-workers
    kubectl get jobs -n batch-workers
    kubectl get daemonsets -n batch-workers

# View worker logs
logs:
    kubectl logs -n batch-workers -l app.kubernetes.io/name=queue-worker --tail=50

# Full workflow
deploy: build apply wait status

# Cleanup
teardown:
    kubectl delete -f k8s.yaml || true
