# AWS region
AWS_REGION=us-east-1

# Populated by `npm run load-outputs` after infra deploy
CLUSTER_AUTOSCALER_ROLE_ARN=arn:aws:iam::123456789012:role/cells-cluster-autoscaler-role
OIDC_PROVIDER_ARN=arn:aws:iam::123456789012:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/EXAMPLE
ECR_REPO_URI=123456789012.dkr.ecr.us-east-1.amazonaws.com/cells-app

# Cell IRSA role ARNs (populated by load-outputs)
CELL_ALPHA_ROLE_ARN=arn:aws:iam::123456789012:role/cells-alpha-role
CELL_BETA_ROLE_ARN=arn:aws:iam::123456789012:role/cells-beta-role
