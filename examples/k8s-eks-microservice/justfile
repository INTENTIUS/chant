chant := "bun run ../../packages/core/src/cli/main.ts"

# Build both outputs
build:
    {{chant}} build src --lexicon aws -o templates/infra.json
    {{chant}} build src --lexicon k8s -o k8s.yaml

# Build K8s manifests only (after .env is populated with real ARNs)
build-k8s:
    {{chant}} build src --lexicon k8s -o k8s.yaml

# Lint all source files
lint:
    {{chant}} lint src

# Deploy AWS infrastructure
deploy-infra:
    aws cloudformation deploy \
        --template-file templates/infra.json \
        --stack-name eks-microservice \
        --capabilities CAPABILITY_NAMED_IAM

# Configure kubectl after infra deploy
configure-kubectl:
    aws eks update-kubeconfig --name eks-microservice --region us-east-1

# Load stack outputs into .env for K8s build (bun auto-loads .env)
load-outputs:
    #!/usr/bin/env bash
    outputs=$(aws cloudformation describe-stacks --stack-name eks-microservice --query 'Stacks[0].Outputs' --output json)
    get() { echo "$outputs" | jq -r ".[] | select(.OutputKey==\"$1\") | .OutputValue"; }
    cat > .env <<EOF
    APP_ROLE_ARN=$(get appRoleArn)
    EXTERNAL_DNS_ROLE_ARN=$(get externalDnsRoleArn)
    FLUENT_BIT_ROLE_ARN=$(get fluentBitRoleArn)
    ADOT_ROLE_ARN=$(get adotRoleArn)
    EOF
    echo "Wrote .env with stack output ARNs"

# Validate K8s manifests against live cluster
validate:
    kubectl apply -f k8s.yaml --dry-run=server

# Apply K8s manifests
apply:
    kubectl apply -f k8s.yaml

# Wait for app rollout
wait:
    kubectl -n microservice rollout status deployment/microservice-api --timeout=120s

# Check deployment status
status:
    kubectl get pods -n microservice
    kubectl get ingress -n microservice
    kubectl get daemonsets -n amazon-cloudwatch
    kubectl get daemonsets -n amazon-metrics

# View app pod logs
logs:
    kubectl logs -n microservice -l app.kubernetes.io/name=microservice-api --tail=50

# Full workflow
deploy: build deploy-infra configure-kubectl load-outputs build-k8s apply wait status

# Cleanup
teardown:
    kubectl delete -f k8s.yaml || true
    @echo "Waiting for ALB to drain..."
    sleep 30
    aws cloudformation delete-stack --stack-name eks-microservice
    aws cloudformation wait stack-delete-complete --stack-name eks-microservice
