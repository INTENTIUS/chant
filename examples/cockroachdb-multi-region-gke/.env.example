# === GCP ===
GCP_PROJECT_ID=                            # REQUIRED — GCP project ID
GCP_PROJECT_NUMBER=                        # REQUIRED — GCP project number (gcloud projects describe $GCP_PROJECT_ID --format='value(projectNumber)')
