{
  "name": "k8s-aks-microservice-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "chant build src --lexicon azure -o template.json && chant build src --lexicon k8s -o k8s.yaml",
    "build:azure": "chant build src --lexicon azure -o template.json",
    "build:k8s": "chant build src --lexicon k8s -o k8s.yaml",
    "lint": "chant lint src",
    "deploy-infra": "az deployment group create --resource-group ${AZURE_RESOURCE_GROUP} --template-file template.json",
    "configure-kubectl": "az aks get-credentials --resource-group ${AZURE_RESOURCE_GROUP} --name aks-microservice --overwrite-existing",
    "load-outputs": "bash scripts/load-outputs.sh",
    "validate": "kubectl apply -f k8s.yaml --dry-run=server",
    "apply": "kubectl apply -f k8s.yaml",
    "wait": "kubectl -n microservice rollout status deployment/microservice-api --timeout=120s",
    "status": "kubectl get pods -n microservice && kubectl get ingress -n microservice && kubectl get daemonsets -n azure-monitor",
    "logs": "kubectl logs -n microservice -l app.kubernetes.io/name=microservice-api --tail=50",
    "deploy": "npm run build && npm run deploy-infra && npm run configure-kubectl && npm run load-outputs && npm run build:k8s && npm run apply && npm run wait && npm run status",
    "teardown": "bash scripts/teardown.sh"
  },
  "dependencies": {
    "@intentius/chant": "workspace:*",
    "@intentius/chant-lexicon-azure": "workspace:*",
    "@intentius/chant-lexicon-k8s": "workspace:*"
  }
}
