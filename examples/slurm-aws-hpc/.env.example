# EDA HPC Slurm Cluster — environment variables
# Copy to .env and fill in your values before running scripts/deploy.sh.

# AWS credentials (or use AWS_PROFILE / instance role instead)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# Target region
AWS_REGION=us-east-1

# Cluster name — used as a prefix for all AWS resource names and SSM parameters.
# Change this if you're running multiple clusters in the same account.
CLUSTER_NAME=eda-hpc
