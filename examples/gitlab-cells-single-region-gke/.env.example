# ── Required ──────────────────────────────────────────────
GCP_PROJECT_ID=my-project
GCP_REGION=us-central1
DOMAIN=gitlab.example.com

# ── GKE cluster sizing (minNodeCount is per-zone; regional cluster = 3 zones) ──
MACHINE_TYPE=e2-standard-8
MIN_NODE_COUNT=3       # 3 × 3 zones = 9 nodes minimum
MAX_NODE_COUNT=20

# ── SMTP (for GitLab email: confirmations, notifications, alerts) ──
# Leave SMTP_PASSWORD blank to deploy without email — GitLab works but won't send email.
# To enable email, choose one option:
#
#   SendGrid (500 free emails/day — https://sendgrid.com):
#     SMTP_ADDRESS=smtp.sendgrid.net  SMTP_USER=apikey  SMTP_PASSWORD=SG.xxxx
#
#   Gmail (500 emails/day, requires 2-Step Verification + App Password):
#     1. Google Account → Security → 2-Step Verification → App passwords → generate for "Mail"
#     2. Set: SMTP_ADDRESS=smtp.gmail.com  SMTP_USER=you@gmail.com  SMTP_DOMAIN=gmail.com
#            SMTP_PASSWORD=xxxx xxxx xxxx xxxx   (16-char app password, spaces ok)
#
#   Enable email after deploy (without redeploying the full stack):
#     echo -n "<password>" | gcloud secrets versions add gitlab-smtp-password \
#       --data-file=- --project <GCP_PROJECT_ID>
#
SMTP_ADDRESS=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
SMTP_DOMAIN=gitlab.example.com
LETSENCRYPT_EMAIL=admin@example.com

# ── GitLab Runner ──
RUNNER_REPLICAS=2
RUNNER_CONCURRENCY=10
RUNNER_NODE_POOL_ENABLED=false      # set to true to isolate runners on dedicated nodes
RUNNER_NODE_POOL_MACHINE_TYPE=e2-standard-4
RUNNER_NODE_POOL_MAX_COUNT=10
INGRESS_REPLICAS=2

# ── Optional: Prometheus remote write (leave blank to disable) ──
PROMETHEUS_REMOTE_WRITE_URL=
