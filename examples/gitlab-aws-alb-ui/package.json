{
  "name": "gitlab-aws-alb-ui-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "chant build src --lexicon aws -o templates/template.json && chant build src --lexicon gitlab -o .gitlab-ci.yml",
    "build:aws": "chant build src --lexicon aws",
    "build:gitlab": "chant build src --lexicon gitlab",
    "dev": "chant build src --watch",
    "lint": "chant lint src"
  },
  "dependencies": {
    "@intentius/chant": "latest",
    "@intentius/chant-lexicon-aws": "latest",
    "@intentius/chant-lexicon-gitlab": "latest"
  }
}
