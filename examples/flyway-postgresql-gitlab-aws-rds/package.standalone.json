{
  "name": "flyway-postgresql-gitlab-aws-rds-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "chant build src --lexicon aws -o templates/template.json && chant build src --lexicon flyway -o flyway.toml && chant build src --lexicon gitlab -o .gitlab-ci.yml",
    "build:aws": "chant build src --lexicon aws",
    "build:flyway": "chant build src --lexicon flyway",
    "build:gitlab": "chant build src --lexicon gitlab",
    "dev": "chant build src --watch",
    "lint": "chant lint src"
  },
  "dependencies": {
    "@intentius/chant": "^0.0.14",
    "@intentius/chant-lexicon-aws": "^0.0.14",
    "@intentius/chant-lexicon-flyway": "^0.0.14",
    "@intentius/chant-lexicon-gitlab": "^0.0.14"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
