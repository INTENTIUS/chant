{
  "name": "chant-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "lexicons/*"
  ],
  "scripts": {
    "tsc": "tsc",
    "docs": "npm --prefix docs run dev",
    "generate": "for d in lexicons/*/; do (cd \"$d\" && npm run generate); done"
  },
  "dependencies": {
    "@intentius/chant-lexicon-aws": "*",
    "@intentius/chant-lexicon-azure": "*",
    "@intentius/chant-lexicon-docker": "*",
    "@intentius/chant-lexicon-flyway": "*",
    "@intentius/chant-lexicon-gcp": "*",
    "@intentius/chant-lexicon-github": "*",
    "@intentius/chant-lexicon-gitlab": "*",
    "@intentius/chant-lexicon-helm": "*",
    "@intentius/chant-lexicon-k8s": "*",
    "@intentius/chant-lexicon-slurm": "*",
    "@intentius/chant-lexicon-temporal": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
